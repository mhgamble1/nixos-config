# secrets.nix — gitignored, create as /etc/nixos/secrets.nix
# Copy this to /etc/nixos/secrets.nix and fill in your values
{
  # SSH authorized keys for the mhg user
  authorizedKeys.mark = [
    # "ssh-ed25519 AAAA... your-key-comment"
  ];

  # Hermes VPS configuration (remote AI agent / workspace)
  hermes = {
    hostname = "your-vps-hostname-or-ip";
    user = "your-username";
  };

  # NAS configuration (only needed for desktop)
  nas = {
    ip = "192.168.x.x";
  };
}
